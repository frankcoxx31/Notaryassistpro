# .env.example
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
# Optional: Defaults to ${APP_URL}/api/auth/google/callback if not set
GOOGLE_REDIRECT_URI=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
VITE_GEMINI_API_KEY=

# Frontend can use these if needed, but prefer server-side for secrets
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE
VITE_GOOGLE_REDIRECT_URI=YOUR_REDIRECT_URI_HERE

# Firebase Admin (server-side only — never expose to the browser)
GOOGLE_SERVICE_ACCOUNT_JSON=
FIREBASE_DATABASE_ID=

# Email sending (verified domain in Resend)
FROM_EMAIL_ADDRESS=noreply@yourdomain.com

# App public URL (used in email footer links and unsubscribe URLs)
APP_URL=https://www.notaryproapp.com

# HMAC secret for signing unsubscribe links (openssl rand -hex 32)
UNSUBSCRIBE_SECRET=

# Svix signing secret from Resend → Webhooks (starts with whsec_)
RESEND_WEBHOOK_SECRET=

# ─── Consent forms & website intake ───────────────────────────────────────────
# HMAC secret for consent signing links (openssl rand -hex 32).
# Falls back to UNSUBSCRIBE_SECRET if left blank, but a separate secret is better.
CONSENT_SECRET=

# How many days a signing link stays valid after it is emailed (default 30)
CONSENT_LINK_DAYS=30

# Firebase UID that website intake leads are assigned to. Required for the
# public /intake form; find it in Firestore under profiles/{uid}.
PUBLIC_INTAKE_UID=

# Comma-separated origins allowed to POST /api/public/intake from another site
# (e.g. a Wix or Squarespace marketing site). Leave blank if the intake form is
# only served from this app.
INTAKE_ALLOWED_ORIGINS=
