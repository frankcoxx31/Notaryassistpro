# .env.example
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
# Optional: Defaults to ${APP_URL}/api/auth/google/callback if not set
GOOGLE_REDIRECT_URI=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=
VITE_GEMINI_API_KEY=

# Frontend can use these if needed, but prefer server-side for secrets
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE
VITE_GOOGLE_REDIRECT_URI=YOUR_REDIRECT_URI_HERE

# Firebase Admin (server-side only — never expose to the browser)
GOOGLE_SERVICE_ACCOUNT_JSON=
FIREBASE_DATABASE_ID=

# Email sending (verified domain in Resend)
FROM_EMAIL_ADDRESS=noreply@yourdomain.com

# App public URL (used in email footer links and unsubscribe URLs)
APP_URL=https://www.notaryproapp.com
