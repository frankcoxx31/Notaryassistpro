rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: appointments
    // Fields: id, date, time, clientName, signingType, location, fee, status, userId, etc.
    //
    // Collection: clients
    // Fields: id, name, company, email, phone, address, userId (Legacy)
    //
    // Collection: customers
    // Fields: id, userId, firstName, lastName, fullName, email, phone, address, city, state, zip, notes, tags, customerType, preferredContactMethod, spouseName, propertyAddress, createdAt, updatedAt
    //
    // Collection: expenses
    // Fields: id, date, category, amount, description, userId
    //
    // Collection: mileage
    // Fields: id, date, description, miles, rate, total, userId
    //
    // Collection: profiles
    // Fields: name, companyName, email, phone, address, commissionNumber, commissionExpiration, userId
    //
    // Collection: savedLookups
    // Fields: id, userId, lawId, savedAt, lawTitle, state, topic
    //
    // Collection: recentSearches
    // Fields: id, userId, query, state, topic, searchedAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isDocOwner() {
      return request.auth != null && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) || 
             !('userId' in resource.data) || 
             request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidAppointment(data) {
      return hasRequiredFields(['id', 'date', 'time', 'signingType', 'location', 'status', 'userId']) &&
             data.id is string && data.id.size() > 0 &&
             data.date is string && data.date.size() > 0 &&
             data.time is string && data.time.size() > 0 &&
             data.signingType is string && data.signingType.size() > 0 &&
             data.location is string && data.location.size() > 0 &&
             data.userId == request.auth.uid &&
             (data.clientName is string || data.customerName is string) &&
             data.status in ['Scheduled', 'Completed', 'Paid', 'Cancelled', 'No Show'] &&
             (!('fee' in data) || data.fee is number) &&
             (!('agreedFee' in data) || data.agreedFee is number);
    }

    function isValidClient(data) {
      return hasRequiredFields(['id', 'name', 'email', 'phone', 'address', 'userId']);
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['id', 'userId', 'firstName', 'lastName', 'fullName', 'email', 'phone', 'address', 'createdAt', 'updatedAt']) &&
             data.firstName is string && data.firstName.size() > 0 && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() > 0 && data.lastName.size() < 100 &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 200 &&
             data.email is string && data.email.size() < 200 &&
             data.phone is string && data.phone.size() < 50;
    }

    function isValidExpense(data) {
      return hasRequiredFields(['id', 'date', 'category', 'amount', 'description', 'userId']) &&
             data.amount is number && data.amount >= 0;
    }

    function isValidMileage(data) {
      return hasRequiredFields(['id', 'date', 'description', 'miles', 'rate', 'total', 'userId']) &&
             data.miles is number && data.miles >= 0 &&
             data.rate is number && data.rate >= 0 &&
             data.total is number && data.total >= 0;
    }

    function isValidProfile(data) {
      // Re-introducing security while keeping it flexible
      return isAuthenticated() && 
             (!('userId' in data) || data.userId == request.auth.uid) &&
             (!('name' in data) || data.name is string) &&
             (!('email' in data) || data.email is string) &&
             (!('phone' in data) || data.phone is string) &&
             (!('companyName' in data) || data.companyName is string) &&
             (!('address' in data) || data.address is string) &&
             (!('state' in data) || data.state is string) &&
             (!('commissionNumber' in data) || data.commissionNumber is string) &&
             (!('commissionExpiration' in data) || data.commissionExpiration is string) &&
             (!('googleCalendarConnected' in data) || data.googleCalendarConnected is bool) &&
             (!('googleCalendarId' in data) || data.googleCalendarId is string) &&
             (!('googleCalendarTokens' in data) || data.googleCalendarTokens == null || data.googleCalendarTokens is map) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidSavedLookup(data) {
      return hasRequiredFields(['id', 'userId', 'lawId', 'savedAt', 'lawTitle', 'state', 'topic']);
    }

    function isValidRecentSearch(data) {
      return hasRequiredFields(['id', 'userId', 'query', 'state', 'topic', 'searchedAt']);
    }

    function isValidSigningCompany(data) {
      return hasRequiredFields(['id', 'userId', 'companyName', 'status', 'createdAt', 'updatedAt']) &&
             (data.status in ['Active', 'Watch', 'Do Not Work With', 'Inactive']);
    }

    function isValidIdvRecord(data) {
      return hasRequiredFields(['id', 'signerId', 'appointmentId', 'status', 'createdAt', 'updatedAt', 'userId']) &&
             data.userId == request.auth.uid &&
             data.id is string && data.id.size() < 100 &&
             data.signerId is string &&
             data.appointmentId is string &&
             data.status is string;
    }

    function isMarketingOwner() {
      return request.auth != null && request.auth.token.email_verified == true && request.auth.uid == resource.data.userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /subscribers/{id} {
      allow read, delete: if isMarketingOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isMarketingOwner() && request.resource.data.userId == resource.data.userId;
    }

    match /marketingSegments/{id} {
      allow read, delete: if isMarketingOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isMarketingOwner() && request.resource.data.userId == resource.data.userId;
    }

    match /marketingCampaigns/{id} {
      allow read, delete: if isMarketingOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isMarketingOwner() && request.resource.data.userId == resource.data.userId;
    }

    match /marketingTemplates/{id} {
      allow read, delete: if isMarketingOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isMarketingOwner() && request.resource.data.userId == resource.data.userId;
    }

    match /marketingAutomations/{id} {
      allow read, delete: if isMarketingOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isMarketingOwner() && request.resource.data.userId == resource.data.userId;
    }

    match /marketingPreferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /emailEvents/{id} {
      allow read: if isMarketingOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /outboundEmailQueue/{id} {
      allow read, delete: if isMarketingOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /appointments/{appointmentId} {
      allow get: if isDocOwner();
      allow list: if isDocOwner();
      allow create: if isAuthenticated() && isValidAppointment(request.resource.data);
      allow update: if isDocOwner() && isValidAppointment(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /signingCompanies/{companyId} {
      allow get: if isDocOwner();
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidSigningCompany(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidSigningCompany(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /clients/{clientId} {
      allow get: if isDocOwner();
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidClient(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidClient(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /customers/{customerId} {
      allow get: if isDocOwner();
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidCustomer(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidCustomer(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /expenses/{expenseId} {
      allow get: if isDocOwner();
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidExpense(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidExpense(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /mileage/{mileageId} {
      allow get: if isDocOwner();
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidMileage(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidMileage(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidProfile(request.resource.data) && uidNotModified();
      allow delete: if isOwner(userId);
    }

    match /savedLookups/{lookupId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSavedLookup(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidSavedLookup(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /recentSearches/{searchId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidRecentSearch(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isDocOwner() && isValidRecentSearch(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /idv_records/{recordId} {
      allow get: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow delete: if isDocOwner();
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidIdvRecord(request.resource.data);
      allow update: if isDocOwner() && isValidIdvRecord(request.resource.data) && uidNotModified();
    }
  }
}
