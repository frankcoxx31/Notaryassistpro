{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A notary signing appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "clientName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "signingType": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "fee": { "type": "number" },
        "status": { "type": "string", "enum": ["Scheduled", "Completed", "Paid", "Cancelled", "No Show"] },
        "notes": { "type": "string" },
        "orderNumber": { "type": "string" },
        "loanNumber": { "type": "string" },
        "durationHours": { "type": "string" },
        "durationMinutes": { "type": "string" },
        "phone": { "type": "string" },
        "homePhone": { "type": "string" },
        "workPhone": { "type": "string" },
        "email": { "type": "string" },
        "customer": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "invoiceSentDate": { "type": "string" },
        "invoicePaidDate": { "type": "string" },
        "sortableDateTime": { "type": "string" },
        "userId": { "type": "string", "description": "The UID of the user who owns this appointment" }
      },
      "required": ["id", "date", "time", "clientName", "signingType", "location", "fee", "status", "userId"]
    },
    "Client": {
      "title": "Client",
      "description": "A client or signing company (Legacy)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone", "address", "userId"]
    },
    "Customer": {
      "title": "Customer",
      "description": "An individual consumer or client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "notes": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "customerType": { "type": "string", "enum": ["Buyer", "Seller", "Borrower", "Signer", "General Client"] },
        "preferredContactMethod": { "type": "string", "enum": ["Email", "Phone", "Text"] },
        "spouseName": { "type": "string" },
        "propertyAddress": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "firstName", "lastName", "fullName", "email", "phone", "address", "createdAt", "updatedAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "category", "amount", "description", "userId"]
    },
    "Mileage": {
      "title": "Mileage",
      "description": "A business mileage record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "miles": { "type": "number" },
        "rate": { "type": "number" },
        "total": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "description", "miles", "rate", "total", "userId"]
    },
    "BusinessProfile": {
      "title": "BusinessProfile",
      "description": "User's business profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "state": { "type": "string" },
        "commissionNumber": { "type": "string" },
        "commissionExpiration": { "type": "string" },
        "userId": { "type": "string" },
        "googleCalendarConnected": { "type": "boolean" },
        "googleCalendarId": { "type": "string" },
        "googleCalendarTokens": { "type": "object" }
      },
      "required": ["name", "companyName", "email", "phone", "address", "commissionNumber", "commissionExpiration", "userId"]
    },
    "SavedLookup": {
      "title": "SavedLookup",
      "description": "A law lookup item saved by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "lawId": { "type": "string" },
        "savedAt": { "type": "string" },
        "lawTitle": { "type": "string" },
        "state": { "type": "string" },
        "topic": { "type": "string" }
      },
      "required": ["id", "userId", "lawId", "savedAt", "lawTitle", "state", "topic"]
    },
    "RecentSearch": {
      "title": "RecentSearch",
      "description": "A recent law search performed by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "state": { "type": "string" },
        "topic": { "type": "string" },
        "searchedAt": { "type": "string" }
      },
      "required": ["id", "userId", "query", "state", "topic", "searchedAt"]
    },
    "SigningCompany": {
      "title": "SigningCompany",
      "description": "A signing company or agency",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "companyName": { "type": "string" },
        "contactName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "address": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Watch", "Do Not Work With", "Inactive"] },
        "preferredPaymentMethod": { "type": "string" },
        "paymentTerms": { "type": "string" },
        "averageFee": { "type": "number" },
        "totalSignings": { "type": "number" },
        "totalCollected": { "type": "number" },
        "totalOutstanding": { "type": "number" },
        "averageDaysToPay": { "type": "number" },
        "lastSigningDate": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "rating": { "type": "number" },
        "paymentReliabilityScore": { "type": "number" },
        "serviceArea": { "type": "string" },
        "portalLoginUrl": { "type": "string" },
        "billingInstructions": { "type": "string" },
        "favorite": { "type": "boolean" }
      },
      "required": ["id", "userId", "companyName", "status", "createdAt", "updatedAt"]
    },
    "IdentityVerificationRecord": {
      "title": "IdentityVerificationRecord",
      "description": "Official identity verification record for a signer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "signerId": { "type": "string" },
        "appointmentId": { "type": "string" },
        "status": { "type": "string" },
        "stage": { "type": "string" },
        "documentType": { "type": "string" },
        "extractedData": { "type": "object" },
        "checks": { "type": "array" },
        "frontImageUrl": { "type": "string" },
        "backImageUrl": { "type": "string" },
        "selfieImageUrl": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "signerId", "appointmentId", "status", "createdAt", "updatedAt", "userId"]
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "User's signing appointments"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "User's clients (Legacy)"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "User's individual customers"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "User's business expenses"
    },
    "/mileage/{mileageId}": {
      "schema": "Mileage",
      "description": "User's mileage records"
    },
    "/profiles/{userId}": {
      "schema": "BusinessProfile",
      "description": "User's business profile"
    },
    "/savedLookups/{lookupId}": {
      "schema": "SavedLookup",
      "description": "User's saved law lookups"
    },
    "/recentSearches/{searchId}": {
      "schema": "RecentSearch",
      "description": "User's recent law searches"
    },
    "/signingCompanies/{companyId}": {
      "schema": "SigningCompany",
      "description": "User's signing companies database"
    },
    "/idv_records/{recordId}": {
      "schema": "IdentityVerificationRecord",
      "description": "Identity verification records"
    }
  }
}
