{
  "entities": {
    "Appointment": {
      "title": "Appointment",
      "description": "A notary signing appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "clientName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "signingType": { "type": "string" },
        "location": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "fee": { "type": "number" },
        "status": { "type": "string", "enum": ["Scheduled", "Completed", "Cancelled", "No Show"] },
        "notes": { "type": "string" },
        "orderNumber": { "type": "string" },
        "loanNumber": { "type": "string" },
        "durationHours": { "type": "string" },
        "durationMinutes": { "type": "string" },
        "userId": { "type": "string", "description": "The UID of the user who owns this appointment" }
      },
      "required": ["id", "date", "time", "clientName", "signingType", "location", "fee", "status", "userId"]
    },
    "Client": {
      "title": "Client",
      "description": "A client or signing company",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "email", "phone", "address", "userId"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "category", "amount", "description", "userId"]
    },
    "Mileage": {
      "title": "Mileage",
      "description": "A business mileage record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "description": { "type": "string" },
        "miles": { "type": "number" },
        "rate": { "type": "number" },
        "total": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "date", "description", "miles", "rate", "total", "userId"]
    },
    "BusinessProfile": {
      "title": "BusinessProfile",
      "description": "User's business profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "commissionNumber": { "type": "string" },
        "commissionExpiration": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "companyName", "email", "phone", "address", "commissionNumber", "commissionExpiration", "userId"]
    }
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "User's signing appointments"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "User's clients"
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "User's business expenses"
    },
    "/mileage/{mileageId}": {
      "schema": "Mileage",
      "description": "User's mileage records"
    },
    "/profiles/{userId}": {
      "schema": "BusinessProfile",
      "description": "User's business profile"
    }
  }
}
